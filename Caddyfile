# Caddyfile — Aria 中继服务器反向代理
# 替换 relay.yourdomain.com 为你的域名

relay.yourdomain.com {
    reverse_proxy relay-server:8765

    # 飞书事件端点
    handle /feishu/* {
        reverse_proxy relay-server:8765
    }

    # WebSocket 中继
    handle /ws {
        reverse_proxy relay-server:8765 {
            transport http {
                # WebSocket 升级头
                header_up Connection "Upgrade"
                header_up Upgrade "websocket"
            }
        }
    }

    log {
        output file /var/log/caddy/relay.log
        format json
    }
}
