#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLI_PY="$SCRIPT_DIR/aria_cli.py"
VENV_PY="$SCRIPT_DIR/.venv/bin/python"

if [[ -x "$VENV_PY" ]]; then
  exec "$VENV_PY" "$CLI_PY" "$@"
fi

# Aria requires Python >= 3.10 (pyproject: requires-python = ">=3.10").
# Bare `python3` may resolve to an older system Python (e.g. /usr/bin/python3
# is 3.9 on macOS), which crashes on import. Pick the first interpreter that
# satisfies 3.10+ so the app never starts under an unsupported runtime.
pick_python() {
  for cand in python3.13 python3.12 python3.11 python3.10 python3; do
    if command -v "$cand" >/dev/null 2>&1; then
      if "$cand" -c 'import sys; sys.exit(0 if sys.version_info >= (3,10) else 1)' 2>/dev/null; then
        echo "$cand"; return 0
      fi
    fi
  done
  return 1
}

PY="$(pick_python || true)"
if [[ -z "$PY" ]]; then
  echo "错误: 未找到 Python 3.10+。Aria 需要 Python >= 3.10。" >&2
  echo "  请安装较新的 Python (https://www.python.org/downloads/) 后重试。" >&2
  exit 1
fi

exec "$PY" "$CLI_PY" "$@"
