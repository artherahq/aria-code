# ~/.aria/.env — Aria Daemon 环境变量配置
# 复制此文件到 ~/.aria/.env 并填入实际值
# cp .env.daemon.template ~/.aria/.env

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# 1. 在 Telegram 中找 @BotFather, 发送 /newbot
# 2. 获得 token 后填入:
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 你的 Telegram Chat ID (发消息给 @userinfobot 获取)
TELEGRAM_ALLOWED_IDS=123456789

# ── APNs (iOS 推送通知) ───────────────────────────────────────────────────────
# 在 Apple Developer Console → Certificates → Keys 创建 APNs Key
# 下载 .p8 文件, 放到 ~/.aria/apns.p8
# 或把内容填到 APNS_AUTH_KEY_P8 (换行替换为 \n)

# Key ID (10位, 如 ABCD1234EF)
APNS_KEY_ID=XXXXXXXXXX

# Team ID (在 Apple Developer 账户页右上角, 10位)
APNS_TEAM_ID=XXXXXXXXXX

# App Bundle ID
APNS_BUNDLE_ID=com.arthera.app

# true = sandbox/TestFlight; false = App Store 正式推送
APNS_SANDBOX=true

# ── 飞书 (Feishu / Lark) ────────────────────────────────────────────────────────
# 方案一：群机器人 Webhook（单向推送，5 分钟完成）
# 飞书群 → 群设置 → 机器人 → 添加机器人 → 自定义机器人 → 复制 Webhook 地址
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxxxxx

# 方案二：自建应用（双向，支持 /price /brief /screen 等命令交互）
# 飞书开发者后台 https://open.feishu.cn/app → 创建自建应用
# 凭证与基本信息 → 复制 App ID 和 App Secret
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 安全设置 → Encrypt Key（可选，生产环境建议开启）
FEISHU_ENCRYPT_KEY=

# 默认推送群 Chat ID（供 POST /api/v1/feishu/webhook 使用）
FEISHU_DEFAULT_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Webhook ────────────────────────────────────────────────────────────────────
# TradingView / 外部系统触发 Aria 命令时验证用
WEBHOOK_TOKEN=your_secret_token

# ── Aria 中继服务（Feishu 多用户分发）────────────────────────────────────────────
# 若使用 Aria 中继服务（推荐，无需自建飞书应用）:
# 1. 运行 python3 setup_wizard.py 生成 ARIA_RELAY_CLIENT_ID
# 2. 在飞书向 Aria Bot 发送: /bind ARIA-BIND-<你的ID>
# 3. 启动 python3 aria_relay_client.py（daemon 自动调用）

ARIA_RELAY_URL=wss://relay.aria.ai
ARIA_RELAY_CLIENT_ID=
ARIA_RELAY_MODE=relay           # relay 或 own_app

# 若自建中继服务器:
# ARIA_RELAY_URL=wss://relay.yourdomain.com

# ── Aria Code 路径 ─────────────────────────────────────────────────────────────
ARIA_CODE_DIR=~/aria-code

# ── FastAPI 后端地址 ────────────────────────────────────────────────────────────
ARIA_API_BASE=http://localhost:8000
