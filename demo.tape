# Aria Code — demo.tape
# Run: vhs demo.tape

Output docs/assets/demo.gif

Set Shell "bash"
Set FontSize 14
Set FontFamily "JetBrains Mono"
Set Width 1100
Set Height 650
Set Theme "Catppuccin Mocha"
Set Padding 20
Set TypingSpeed 1ms
Set PlaybackSpeed 1.0
Set LoopOffset 50%
Set CursorBlink false

Sleep 200ms
Type "python3 demo_player.py"
Enter
Sleep 32s
